# This file is intended for inclusion from nginx's http context.
limit_req_zone $binary_remote_addr zone=ena3d_per_ip:10m rate=10r/s;
map $http_upgrade $ena3d_connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;
    server_name 3dena.com www.3dena.com;
    return 301 https://3dena.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.3dena.com;

    # This certificate must include both 3dena.com and www.3dena.com as SANs.
    ssl_certificate /etc/letsencrypt/live/3dena.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/3dena.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    return 301 https://3dena.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name 3dena.com;

    ssl_certificate /etc/letsencrypt/live/3dena.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/3dena.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 2m;
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    location = /healthz {
        proxy_pass http://127.0.0.1:3838/ena3d-health/healthz.json;
        proxy_set_header Host $host;
        access_log off;
    }

    location / {
        limit_req zone=ena3d_per_ip burst=30 nodelay;
        proxy_pass http://127.0.0.1:3838;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $ena3d_connection_upgrade;
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
