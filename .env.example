# Build provenance is required by compose.production.yaml.
ENA3D_BUILD_ID=replace-with-an-immutable-commit-sha
ENA3D_APP_VERSION=0.2.0-dev

# Qwen is fail-closed. compose.production.yaml keeps this false; the optional
# compose.qwen.yaml overlay changes it to true.
ENA3D_AI_ENABLED=false

# These three values must describe the same Alibaba Cloud Model Studio region.
# The example uses the shared China (Beijing) endpoint. See
# docs/AI_INTERPRETATION.md for Singapore, US (Virginia), and workspace URLs.
ENA3D_QWEN_REGION=cn-beijing
ENA3D_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ENA3D_QWEN_MODEL=qwen3.7-max-2026-06-08

# This is a host file path, not an API key. Keep the file outside this
# repository. compose.qwen.yaml mounts it read-only into the container.
ENA3D_DASHSCOPE_SECRET_FILE=/absolute/path/outside/repository/dashscope_api_key

# Provider request bounds.
ENA3D_QWEN_TIMEOUT_SECONDS=60
ENA3D_QWEN_CONNECT_TIMEOUT_SECONDS=10
ENA3D_QWEN_MAX_REQUEST_BYTES=262144
ENA3D_QWEN_MAX_RESPONSE_BYTES=262144
ENA3D_QWEN_MAX_CONTEXT_BYTES=8192
ENA3D_QWEN_MAX_COMPLETION_TOKENS=4096
ENA3D_QWEN_THINKING_BUDGET=1536
ENA3D_QWEN_TEMPERATURE=0.1

# Local evidence, privacy, and workload bounds.
ENA3D_AI_MIN_CELL_N=5
ENA3D_AI_TOP_N=10
ENA3D_AI_CONTEXT_MAX_CHARS=1500
ENA3D_AI_MAX_CONCURRENT_JOBS=4
ENA3D_AI_MAX_REQUESTS_PER_HOUR=10
ENA3D_AI_MAX_EVIDENCE_BYTES=65536
